{
  "name": "subwaybuilder-improved-schematics",
  "version": "1.2.0",
  "description": "Improved geographic schematic map mod for Subway Builder",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "postbuild": "tsx scripts/install.ts",
    "dev": "concurrently -k -n build,game -c blue,green \"vite build --watch\" \"tsx scripts/run.ts\"",
    "dev:link": "tsx scripts/link.ts",
    "dev:unlink": "tsx scripts/link.ts --unlink",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "render": "tsx dev/render-test.ts"
  },
  "keywords": [
    "subway-builder",
    "mod",
    "schematic",
    "map"
  ],
  "author": "Giancarlo Martinelli (gcm)",
  "license": "MIT",
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^25.0.9",
    "@types/react": "^19.2.9",
    "concurrently": "^9.2.1",
    "maplibre-gl": "^5.18.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vite": "npm:rolldown-vite@latest",
    "vite-plugin-static-copy": "^3.0.0"
  }
}
