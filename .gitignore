# essential config (tracked despite the broad *.json rule above)
!package.json
!tsconfig.json
!manifest.json
# active test dumps the diagnostics/convergence run on (tracked despite *.json;
# other/older dumps and all *.geojson stay ignored — regenerated from the game)
!improvedschematics-input-chi.json
!improvedschematics-dump-sea-w-geo.json
!improvedschematics-input-nyc.json
# dev tooling: track the scripts (harnesses + probes), keep artifacts ignored.
# NOTE: `dev/*` (not `dev/`) so the `!` re-include below can take effect —
# git can't re-include a file whose parent DIRECTORY is excluded. Images
# (*.png/*.svg) and dev data (*.json/*.geojson) stay ignored via the globals.
dev/*
!dev/*.ts
# ...EXCEPT one-off scratch/debug scripts (underscore-prefixed: crop/probe/parity-
# investigation/chk/dbg etc.) — local-only, not needed on another machine. Named tooling
# (dev/<name>.ts, e.g. render-test) stays tracked. To keep a specific underscore script
# (e.g. a golden-master harness), add a `!dev/_that-one.ts` line below this.
dev/_*.ts
# ...but KEEP the reusable harnesses trackable: the golden-master regression draw and the
# canvas-vs-SVG / scene parity checks (the `_parity-*` files are one-off investigations).
!dev/_golden-draw.ts
!dev/_scene-parity.ts
!dev/_svg-vs-canvas.ts
examplesave_seattle/
